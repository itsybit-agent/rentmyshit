<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <!-- /{slug}/admin → owner dashboard -->
        <rule name="Owner Dashboard" stopProcessing="true">
          <match url="^([a-z0-9][a-z0-9\-]*[a-z0-9])/admin$" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="/slices/owner/dashboard/?slug={R:1}" />
        </rule>

        <!-- /{slug} or /{slug}?t=token → borrower browse -->
        <rule name="Borrower Browse" stopProcessing="true">
          <match url="^([a-z0-9][a-z0-9\-]*[a-z0-9])$" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="/slices/borrower/browse/?slug={R:1}" appendQueryString="true" />
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>
